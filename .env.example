# Copy this file to .env and fill in the key for the provider you use.
# The app works without any key too - it then falls back to an offline,
# template-based explanation.

# Which LLM provider to use: openai | groq | gemini | claude
AI_PROVIDER=openai

# Optional: override the default model for the chosen provider.
# AI_MODEL=gpt-4o-mini

# Provider API keys (set only the one you need):
OPENAI_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
